{
  "name": "novabyte-server",
  "version": "3.0.2",
  "description": "NovaByte Server",
  "main": "client.js",
  "scripts": {
    "start": "nw .",
    "prestart": "node scripts/bootstrap.js",
    "dev": "nw . --enable-logging=stderr --v=1",
    "test": "npx vitest run --reporter=verbose",
    "clean": "node -e \"const {exec}=require('child_process');exec(process.platform==='win32'?'taskkill /F /IM nw.exe':'pkill -x nw; pkill -x nwjs; exit 0',()=>console.log('\\u2714 Cleared.'))\""
  },
  "window": {
    "title": "NovaByte",
    "width": 1280,
    "height": 720,
    "min_width": 800,
    "min_height": 500,
    "frame": true,
    "icon": "assets/icon.png",
    "icons": {
      "128": "assets/icon.png"
    },
    "dev_tools": true,
    "chromium-args": "--no-first-run --disable-features=Vulkan,CalculateNativeWinOcclusion --disable-zero-copy --js-flags=\"--expose-gc --max-old-space-size=512\" --ignore-gpu-blocklist --disable-background-timer-throttling --disable-renderer-backgrounding --user-data-dir=./nwjs-data --remote-debugging-port=9222 --auto-open-devtools-for-tabs --disable-web-security --allow-file-access-from-files"
  },
  "node-remote": "https://localhost:*",
  "keywords": [
    "Server"
  ],
  "author": "NovaByteOfficial",
  "license": "Apache-2.0",
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@noble/post-quantum": "^0.6.1",
    "@peculiar/x509": "^2.0.0",
    "better-sqlite3": "^13.0.1",
    "better-sqlite3-session-store": "^0.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dompurify": "^3.4.12",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "express-session": "^1.19.0",
    "helmet": "^8.3.0",
    "i18next": "^26.3.6",
    "imapflow": "^1.5.0",
    "node-pop3": "^0.11.0",
    "nodemailer": "^9.0.3",
    "postal-mime": "^2.7.5",
    "reflect-metadata": "^0.2.2",
    "tar": "^7.5.21",
    "undici": "^8.8.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.11.1",
    "jsdom": "^29.1.1",
    "nw": "^0.113.0-sdk",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "nw@0.113.0-sdk": true,
    "better-sqlite3@13.0.1": true
  }
}

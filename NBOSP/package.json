{
  "name": "novabyte-server",
  "version": "3.0.2",
  "description": "NovaByte Server",
  "main": "client.js",
  "scripts": {
    "start": "nw ."
  },
  "window": {
    "title": "NovaByte",
    "width": 1280,
    "height": 720,
    "min_width": 800,
    "min_height": 500,
    "frame": true,
    "icon": "assets/icon.png",
    "icons": {
      "128": "assets/icon.png"
    },
    "dev_tools": true,
    "chromium-args": "--no-first-run --renderer-process-limit=1 --disable-features=Vulkan,CanvasOopRasterization --disable-zero-copy --js-flags=--max-old-space-size=4096 --expose-gc"
  },
  "node-remote": "https://localhost:*",
  "keywords": [
    "Server"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dompurify": "^3.4.8",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "imapflow": "^1.3.5",
    "node-pop3": "^0.11.0",
    "nodemailer": "^8.0.10",
    "postal-mime": "^2.7.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "nw": "^0.112.0-sdk"
  },
  "allowScripts": {
    "nw@0.112.0-sdk": true
  }
}
